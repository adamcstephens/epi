(rule
 (with-stdout-to
  link_flags.linux
  (bash "if [ \"${BUILD_STATIC:-0}\" = '1' ]; then echo '(-cclib -static)'; else echo '()'; fi")))

(rule
 (with-stdout-to
  link_flags.macosx
  (echo "()")))

(executables
 (names project_name)
 (public_names project-name)
 (libraries project_name)
 (link_flags
  (:include link_flags.%{system})))
